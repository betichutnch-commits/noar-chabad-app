# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: required for cross-user notifications (push prefs, inserts to other users' notifications)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used in email links and push click-through)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Optional fallback for legacy FCM/GCM endpoints returning "Invalid API key"
GCM_API_KEY=

# Email fallback (Resend — https://resend.com)
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@your-verified-domain.com
